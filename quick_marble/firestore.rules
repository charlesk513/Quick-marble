rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }

    function isActiveUser() {
      return hasUserProfile()
        && userDoc().data.isActive == true;
    }

    function isAdmin() {
      return isActiveUser()
        && userDoc().data.role == 'admin';
    }

    function userOfficeId() {
      return userDoc().data.assignedOfficeId;
    }

    function canAccessOffice(officeId) {
      return isAdmin()
        || (
          isActiveUser()
          && officeId != null
          && officeId == userOfficeId()
        );
    }

    function canAccessExistingOfficeRecord() {
      return canAccessOffice(resource.data.officeId);
    }

    function canCreateOfficeRecord() {
      return canAccessOffice(request.resource.data.officeId);
    }

    function keepsOfficeScope() {
      return isAdmin()
        || request.resource.data.officeId == resource.data.officeId;
    }

    match /users/{userId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /offices/{officeId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isActiveUser() && canAccessExistingOfficeRecord();
      allow create: if isActiveUser() && canCreateOfficeRecord();
      allow update: if isActiveUser()
        && canAccessExistingOfficeRecord()
        && canAccessOffice(request.resource.data.officeId)
        && keepsOfficeScope();
      allow delete: if isAdmin();
    }

    match /quotations/{quotationId} {
      allow read: if isActiveUser() && canAccessExistingOfficeRecord();
      allow create: if isActiveUser() && canCreateOfficeRecord();
      allow update: if isActiveUser()
        && canAccessExistingOfficeRecord()
        && canAccessOffice(request.resource.data.officeId)
        && keepsOfficeScope();
      allow delete: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isActiveUser() && canAccessExistingOfficeRecord();
      allow create: if isActiveUser() && canCreateOfficeRecord();
      allow update: if isActiveUser()
        && canAccessExistingOfficeRecord()
        && canAccessOffice(request.resource.data.officeId)
        && keepsOfficeScope();
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if isActiveUser() && canAccessExistingOfficeRecord();
      allow create: if isActiveUser() && canCreateOfficeRecord();
      allow update: if isActiveUser()
        && canAccessExistingOfficeRecord()
        && canAccessOffice(request.resource.data.officeId)
        && keepsOfficeScope();
      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isActiveUser()
        && (isAdmin() || resource.data.officeId == userOfficeId());

      allow create: if isActiveUser()
        && (isAdmin() || request.resource.data.officeId == userOfficeId());

      allow update, delete: if isAdmin();
    }

    match /project_timelines/{eventId} {
      allow read: if isActiveUser()
        && (isAdmin() || resource.data.officeId == userOfficeId());

      allow create: if isActiveUser()
        && (isAdmin() || request.resource.data.officeId == userOfficeId());

      allow update, delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read, write: if isActiveUser();
    }

    match /settings/{settingId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
